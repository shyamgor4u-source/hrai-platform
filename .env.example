# ── HRAI Intelligence Platform — Environment Variables ──────────────────────
# Copy this file to .env and fill in your values.

# Database — PostgreSQL (required for Vercel deployment)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/hrai_db"

# JWT secret — use a long random string in production
JWT_SECRET="hrai-super-secret-jwt-key-change-this-in-production-2025"
JWT_EXPIRES_IN="7d"

# Anthropic API key — stored securely on the server (never exposed to the browser)
ANTHROPIC_API_KEY="sk-ant-..."

# Server
PORT=3000
NODE_ENV="development"

# CORS — set to your Vercel domain in production (e.g. https://your-app.vercel.app)
CORS_ORIGIN="http://localhost:3000"
